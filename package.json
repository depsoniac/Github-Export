{
  "name": "clipdock",
  "version": "1.0.5",
  "private": false,
  "description": "Descargas, procesamiento multimedia e integración con Adobe en una sola mesa de trabajo.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist:win": "electron-builder --win portable",
    "dist:mac": "electron-builder --mac",
    "export": "node build-tools/exportar.js",
    "export:win": "node build-tools/exportar.js --target win",
    "export:mac": "node build-tools/exportar.js --target mac",
    "export:mac-runtime": "node build-tools/exportar.js --target mac-runtime",
    "export:all": "node build-tools/exportar.js --target all"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "socket.io-client": "^4.8.1",
    "electron-builder": "^26.0.0"
  },
  "productName": "ClipDock",
  "author": "Depson",
  "build": {
    "appId": "com.clipdock.app",
    "productName": "ClipDock",
    "copyright": "Copyright © 2026 Depson",
    "compression": "store",
    "asar": true,
    "directories": {
      "output": "release-dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "update-config.json",
      "renderer/**",
      "assets/**",
      "runtime/**",
      "!runtime/python/**",
      "!**/*.bat",
      "!backend/**",
      "!engine/**",
      "!dist/**",
      "!release-dist/**",
      "!**/__pycache__/**",
      "!**/.venv/**",
      "!**/.build/**",
      "!unins000.*",
      "!build-tools/**",
      "!.build/**",
      "!build/**"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "engine",
        "to": "engine",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!.venv/**",
          "!bin/**"
        ]
      }
    ],
    "win": {
      "target": "portable",
      "icon": "assets/clipdock.ico",
      "signExecutable": false
    },
    "portable": {
      "artifactName": "ClipDock_Setup_${version}.${ext}",
      "requestExecutionLevel": "user",
      "splashImage": "build/installerSplash.bmp"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/clipdock-512.png",
      "category": "public.app-category.video",
      "artifactName": "ClipDock_Mac_${version}_${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false
    },
    "executableName": "ClipDock"
  }
}
